rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    // UPDATED: Added exists() check to prevent errors for new users
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function hasPendingInvite() {
      return request.auth != null &&
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower()));
    }
    
    // Settings collection (NEW)
    match /settings/{document=**} {
      allow read: if request.auth != null; // All logged-in users can read settings
      allow write: if isAdmin(); // Only admins can save settings
    }

    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        isAdmin() || 
        request.auth.token.email.lower() == resource.data.email.lower()
      );
      
      allow create: if isAdmin() || (
        request.auth != null &&
        request.auth.uid == userId &&
        hasPendingInvite()
      );
      
      allow update: if request.auth != null && (
        (request.auth.token.email.lower() == resource.data.email.lower() && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      
      // UPDATED: Allow users to delete their own invite record during signup
      allow delete: if isAdmin() || (
        request.auth != null && 
        resource.data.email.lower() == request.auth.token.email.lower()
      );
    }
    // Shipments collection
    match /shipments/{shipmentId} {
      allow read, write, delete: if true;
    }
    
    // Addresses collection
    match /addresses/{addressId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
  }
}
